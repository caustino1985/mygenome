plot_prs_distribution <- function(prs_result) {
  """
  Plot PRS score distribution with percentile rank
  """
  
  # Generate normal distribution
  x <- seq(-4, 4, length = 1000)
  y <- dnorm(x)
  
  # Create data frame for plotting
  dist_df <- data.frame(x = x, y = y)
  
  # Create plot
  p <- ggplot(dist_df, aes(x = x, y = y)) +
    geom_line(color = "blue", size = 1) +
    geom_area(aes(x = ifelse(x <= prs_result$prs_score, x, NA)), 
              fill = "lightblue", alpha = 0.5) +
    geom_vline(xintercept = prs_result$prs_score, 
               color = "red", linetype = "dashed", size = 1) +
    geom_vline(xintercept = prs_result$confidence_interval_lower, 
               color = "orange", linetype = "dotted", size = 0.8) +
    geom_vline(xintercept = prs_result$confidence_interval_upper, 
               color = "orange", linetype = "dotted", size = 0.8) +
    labs(
      title = "Polygenic Risk Score Distribution",
      subtitle = paste("PRS Score:", round(prs_result$prs_score, 2), 
                       "| Percentile:", round(prs_result$prs_percentile, 1), "%"),
      x = "PRS Score (Standard Deviations)",
      y = "Probability Density",
      caption = "Red line: PRS score | Orange lines: 95% Confidence Interval"
    ) +
    theme_minimal() +
    theme(
      plot.title = element_text(face = "bold", size = 14),
      plot.subtitle = element_text(size = 12),
      axis.title = element_text(size = 11),
      panel.grid.major = element_line(color = "gray90"),
      panel.grid.minor = element_blank()
    )
  
  return(p)
}

plot_effect_sizes <- function(genotypes_df) {
  """
  Plot effect sizes for significant markers
  """
  
  # Merge genotypes with markers
  merged_df <- merge(genotypes_df, genetic_markers, by = "snp_id")
  
  # Sort by effect size
  merged_df <- merged_df[order(merged_df$effect_size, decreasing = TRUE), ]
  
  # Create plot
  p <- ggplot(merged_df, aes(x = reorder(snp_id, effect_size), y = effect_size)) +
    geom_bar(stat = "identity", fill = "steelblue", color = "black") +
    geom_hline(yintercept = 0.1, linetype = "dashed", color = "red", size = 0.8) +
    coord_flip() +
    labs(
      title = "Effect Sizes by Genetic Marker",
      subtitle = "Red dashed line indicates significance threshold (0.1)",
      x = "SNP ID",
      y = "Effect Size"
    ) +
    theme_minimal() +
    theme(
      plot.title = element_text(face = "bold", size = 14),
      plot.subtitle = element_text(size = 12),
      axis.title = element_text(size = 11)
    )
  
  return(p)
}

