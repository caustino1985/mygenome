generate_ssdi_appeal_brief <- function(
  claimant_name,
  genotypes_df,
  prs_result,
  ssa_listing = "12.02"
) {
  """
  Generate SSI/SSDI appeal brief from genetic data
  """
  
  # Merge genotypes with markers
  merged_df <- merge(genotypes_df, genetic_markers, by = "snp_id")
  
  # Filter for relevant SSA listing
  relevant_markers <- merged_df[merged_df$ssa_listing == ssa_listing, ]
  
  # Generate brief text
  brief <- paste0(
    "BRIEF IN SUPPORT OF APPEAL OF SOCIAL SECURITY ADMINISTRATION DECISION\n\n",
    
    "I. INTRODUCTION\n\n",
    "This brief is submitted on behalf of ", claimant_name, 
    " in support of an appeal of the Social Security Administration's denial of ",
    "Social Security Disability Insurance (SSDI) benefits.\n\n",
    
    "II. GENETIC EVIDENCE\n\n",
    "A. Polygenic Risk Score Analysis\n\n",
    "The claimant's genetic testing reveals a PRS score of ", 
    round(prs_result$prs_score, 2), 
    " at the ", round(prs_result$prs_percentile, 1), 
    "th percentile, indicating a high genetic risk for ADHD and related ",
    "neurodevelopmental conditions. This score is based on analysis of ",
    prs_result$genetic_markers_count, " genetic markers, of which ",
    prs_result$genetic_markers_significant, " are statistically significant.\n\n",
    
    "B. Genetic Markers Supporting SSA Listing ", ssa_listing, "\n\n",
    "The following genetic markers directly support SSA Listing ", ssa_listing, ":\n\n"
  )
  
  # Add marker details
  for (i in 1:nrow(relevant_markers)) {
    marker <- relevant_markers[i, ]
    brief <- paste0(
      brief,
      i, ". ", marker$snp_id, " (", marker$gene_name, ")\n",
      "   - Genotype: ", marker$genotype, "\n",
      "   - Functional Impact: ", marker$functional_impact, "\n",
      "   - Associated Condition: ", marker$associated_condition, "\n",
      "   - Legal Significance: This marker establishes objective evidence of ",
      tolower(marker$functional_impact), 
      ", directly supporting SSA Listing ", marker$ssa_listing, ".\n\n"
    )
  }
  
  # Add legal argument
  brief <- paste0(
    brief,
    "III. LEGAL ARGUMENT\n\n",
    "A. SSA Listing ", ssa_listing, " (ADHD)\n\n",
    "SSA Listing ", ssa_listing, " requires evidence of:\n\n",
    "1. Persistent or recurrent symptoms of inattention and/or hyperactivity-impulsivity\n",
    "2. Onset in childhood\n",
    "3. Functional limitations in at least two major life activities\n\n",
    "The claimant's genetic evidence establishes all three criteria:\n\n",
    "1. Genetic markers establish neurochemical basis for inattention and executive dysfunction.\n",
    "2. Genetic predisposition to ADHD typically manifests in childhood.\n",
    "3. Functional limitations include difficulty sustaining attention, executive dysfunction, ",
    "and impulse control deficits, affecting employment and daily functioning.\n\n",
    
    "IV. CONCLUSION\n\n",
    "For the foregoing reasons, the claimant respectfully requests that this Court reverse ",
    "the SSA's denial of SSDI benefits and remand for award of benefits.\n\n",
    "Respectfully submitted,\n\n",
    claimant_name, "\n",
    "Pro Se Claimant\n",
    format(Sys.Date(), "%B %d, %Y")
  )
  
  return(brief)
}

# ============================================================================
# SECTION 8: BLOCKCHAIN EVIDENCE VERIFICATION
# ============================================================================

generate_evidence_packet <- function(
  genotypes_df,
  prs_result,
  cartridge_uid
) {
  """
  Generate evidence packet for blockchain anchoring
  """
  
  # Create evidence object
  evidence <- list(
    cartridge_uid = cartridge_uid,
    timestamp = format(Sys.time(), "%Y-%m-%dT%H:%M:%SZ"),
    genotypes = genotypes_df,
    prs = prs_result,
    metadata = list(
      platform = "USB-C Electrochemical Genotyping",
      version = "1.0",
      pqc_algorithm = "Dilithium2022",
      blockchain = "Hyperledger Fabric"
    )
  )
  
  # Convert to JSON
  evidence_json <- toJSON(evidence, pretty = TRUE)
  
  # Calculate hash
  evidence_hash <- digest::digest(evidence_json, algo = "sha256")
  
  evidence$evidence_hash <- evidence_hash
  
  return(evidence)
}

